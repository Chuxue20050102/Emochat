{
  "name": "emochat-frontend",
  "version": "1.0.0",
  "description": "EmoChat 情绪聊天应用前端",
  "scripts": {
    "dev:h5": "set UNI_INPUT_DIR=.&& uni",
    "build:h5": "set UNI_INPUT_DIR=.&& uni build",
    "dev:mp-weixin": "set UNI_INPUT_DIR=.&& uni -p mp-weixin",
    "build:mp-weixin": "set UNI_INPUT_DIR=.&& uni build -p mp-weixin",
    "dev:mp-alipay": "set UNI_INPUT_DIR=.&& uni -p mp-alipay",
    "build:mp-alipay": "set UNI_INPUT_DIR=.&& uni build -p mp-alipay",
    "dev:app": "set UNI_INPUT_DIR=.&& uni -p app",
    "build:app": "set UNI_INPUT_DIR=.&& uni build -p app"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4010520240507001",
    "@dcloudio/uni-app-plus": "3.0.0-4010520240507001",
    "@dcloudio/uni-components": "3.0.0-4010520240507001",
    "@dcloudio/uni-h5": "3.0.0-4010520240507001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4010520240507001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4010520240507001",
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4010520240507001",
    "@dcloudio/uni-cli-shared": "3.0.0-4010520240507001",
    "@dcloudio/uni-stacktracey": "3.0.0-4010520240507001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4010520240507001",
    "sass": "^1.99.0",
    "typescript": "^5.4.5",
    "vite": "5.2.8"
  }
}
